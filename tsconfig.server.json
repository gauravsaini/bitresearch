{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist/server",
    "rootDir": "./server",
    "lib": ["ES2022"]
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules"]
}
