{
  "name": "webgpu-distributed-training",
  "version": "0.1.0",
  "description": "Distributed GPT training across WebGPU browser workers",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:p2p": "concurrently \"pnpm run dev:signaling\" \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:signaling": "tsx watch server/signaling.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "@petamoriken/float16": "^3.9.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-webgpu": "^4.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.12",
    "@webgpu/types": "^0.1.51",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
